# Copy to .env for local docker run against Aurora (do not commit .env)
SPRING_PROFILES_ACTIVE=prod
AWS_REGION=eu-north-1
SPRING_DATASOURCE_URL=jdbc:aws-wrapper:postgresql://your-cluster-host:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
# No password — IAM auth via AWS credential chain (mount ~/.aws or use ECS task role)
PORT=8080
